DEBUG=False
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_TO_A_LONG_RANDOM_STRING
ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.com
DATABASE_URL=postgresql://user:password@localhost:5432/lauda_db

# Security headers and cookies
SECURE_SSL_REDIRECT=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
X_FRAME_OPTIONS=DENY

# JWT
JWT_SECRET_KEY=${SECRET_KEY}
ACCESS_TOKEN_LIFETIME_HOURS=1
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://seu-frontend.com
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\\.trycloudflare\\.com$,^https://.*\\.workers\\.dev$,^https://.*\\.pages\\.dev$
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://seu-frontend.com,https://*.trycloudflare.com,https://*.workers.dev,https://*.pages.dev

# Email / SMTP
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@seu-dominio.com

# External integrations
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=BR
GENIUS_ACCESS_TOKEN=
EXTERNAL_API_TIMEOUT=10
MUSIC_METADATA_CACHE_TTL=86400
SPOTIFY_THROTTLE_SECONDS=0.35
GENIUS_THROTTLE_SECONDS=0.9

# Observability
SENTRY_DSN=
